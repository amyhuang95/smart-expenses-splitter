{
  "name": "spliteasy-backend",
  "version": "1.0.0",
  "description": "A shared expense tracking platform that helps groups split bills, calculate balances, and settle debts.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "npx nodemon --watch server.js",
    "seed": "node seed.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "expense",
    "splitter",
    "group",
    "balance",
    "tracker",
    "express",
    "mongodb"
  ],
  "author": "Pangta Huang & Amy Huang",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "mongodb": "^6.12.0",
    "bcrypt": "^6.0.0",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.0.0",
    "nodemon": "^3.1.11"
  }
}
